# Luminous Gastronomy Platform - Deployment Config
# --------------------------------------------------

# 1. Supabase Connection (Required for persistence)
# Get these from your Supabase Dashboard -> Settings -> API
VITE_SUPABASE_URL=your_project_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# 2. Platform Settings
VITE_PLATFORM_NAME=Luminous Gastronomy
VITE_DEFAULT_LOCALE=en

# Note: If credentials are not provided, the app will 
# automatically operate in 'Smart Persistence' mode (Demo Mode)
# using LocalStorage for all merchant and customer actions.
